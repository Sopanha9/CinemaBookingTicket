// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`


generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// 1. USERS
// ==========================================
model User {
  id        Int       @id @default(autoincrement()) @map("user_id")
  name      String    @db.VarChar(100)
  email     String    @unique @db.VarChar(100)
  password  String    @db.VarChar(255)
  phone     String?   @db.VarChar(20)
  role      Role      @default(customer)
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  bookings  Booking[]
  reviews   Review[]
  seatLocks SeatLock[]

  @@map("users")
}

enum Role {
  customer
  admin
}

// ==========================================
// 2. THEATERS
// ==========================================
model Theater {
  id        Int       @id @default(autoincrement()) @map("theater_id")
  name      String    @db.VarChar(100)
  location  String    @db.VarChar(255)
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")

  screens   Screen[]

  @@map("theaters")
}

// ==========================================
// 3. SCREENS
// ==========================================
model Screen {
  id           Int        @id @default(autoincrement()) @map("screen_id")
  theaterId    Int        @map("theater_id")
  name         String     @db.VarChar(50)
  screenType   ScreenType @default(regular) @map("screen_type")
  totalRows    Int        @map("total_rows")
  totalColumns Int        @map("total_columns")
  isActive     Boolean    @default(true) @map("is_active")
  createdAt    DateTime   @default(now()) @map("created_at")

  theater      Theater    @relation(fields: [theaterId], references: [id])
  seats        Seat[]
  showtimes    Showtime[]

  @@map("screens")
}

enum ScreenType {
  regular
  imax
  threeD @map("3d")
  fourDx @map("4dx")
}

// ==========================================
// 4. SEATS
// ==========================================
model Seat {
  id           Int       @id @default(autoincrement()) @map("seat_id")
  screenId     Int       @map("screen_id")
  seatNumber   String    @map("seat_number") @db.VarChar(10)
  rowNumber    Int       @map("row_number")
  columnNumber Int       @map("column_number")
  seatType     SeatType  @default(normal) @map("seat_type")
  isActive     Boolean   @default(true) @map("is_active")

  screen       Screen    @relation(fields: [screenId], references: [id], onDelete: Cascade)
  seatLocks    SeatLock[]
  bookingSeats BookingSeat[]

  @@unique([screenId, rowNumber, columnNumber])
  @@map("seats")
}

enum SeatType {
  normal
  vip
  premium
  wheelchair
}

// ==========================================
// 5. MOVIES
// ==========================================
model Movie {
  id          Int          @id @default(autoincrement()) @map("movie_id")
  title       String       @db.VarChar(255)
  duration    Int          // Duration in minutes
  description String?      @db.Text
  releaseDate DateTime?    @map("release_date") @db.Date
  posterUrl   String?      @map("poster_url") @db.VarChar(500)
  language    String?      @db.VarChar(50)
  ageRating   AgeRating    @default(PG) @map("age_rating")
  status      MovieStatus  @default(upcoming)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  genres      MovieGenre[]
  showtimes   Showtime[]
  reviews     Review[]

  @@map("movies")
}

enum AgeRating {
  G
  PG
  PG_13 @map("PG-13")
  R
  NC_17 @map("NC-17")
}

enum MovieStatus {
  upcoming
  now_showing
  ended
}

// ==========================================
// 6. GENRES & MOVIE_GENRES
// ==========================================
model Genre {
  id     Int          @id @default(autoincrement()) @map("genre_id")
  name   String       @unique @db.VarChar(50)
  movies MovieGenre[]

  @@map("genres")
}

model MovieGenre {
  movieId Int @map("movie_id")
  genreId Int @map("genre_id")

  movie   Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)
  genre   Genre @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([movieId, genreId])
  @@map("movie_genres")
}

// ==========================================
// 8. PRICING RULES
// ==========================================
model PricingRule {
  id         Int        @id @default(autoincrement()) @map("pricing_id")
  screenType ScreenType @map("screen_type")
  seatType   SeatType   @map("seat_type")
  dayType    DayType    @map("day_type")
  basePrice  Decimal    @map("base_price") @db.Decimal(10, 2)
  createdAt  DateTime   @default(now()) @map("created_at")

  @@unique([screenType, seatType, dayType])
  @@map("pricing_rules")
}

enum DayType {
  weekday
  weekend
  holiday
}

// ==========================================
// 9. SHOWTIMES
// ==========================================
model Showtime {
  id          Int            @id @default(autoincrement()) @map("showtime_id")
  movieId     Int            @map("movie_id")
  screenId    Int            @map("screen_id")
  startTime   DateTime       @map("start_time")
  endTime     DateTime       @map("end_time")
  basePrice   Decimal        @map("base_price") @db.Decimal(10, 2)
  status      ShowtimeStatus @default(scheduled)
  createdAt   DateTime       @default(now()) @map("created_at")

  movie       Movie          @relation(fields: [movieId], references: [id])
  screen      Screen         @relation(fields: [screenId], references: [id])
  bookings    Booking[]
  seatLocks   SeatLock[]
  bookingSeats BookingSeat[]

  @@unique([screenId, startTime])
  @@index([startTime, status])
  @@map("showtimes")
}

enum ShowtimeStatus {
  scheduled
  cancelled
  completed
}

// ==========================================
// 10. SEAT LOCKS
// ==========================================
model SeatLock {
  id          Int      @id @default(autoincrement()) @map("lock_id")
  seatId      Int      @map("seat_id")
  showtimeId  Int      @map("showtime_id")
  userId      Int      @map("user_id")
  lockedUntil DateTime @map("locked_until")
  createdAt   DateTime @default(now()) @map("created_at")

  seat     Seat     @relation(fields: [seatId], references: [id])
  showtime Showtime @relation(fields: [showtimeId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([seatId, showtimeId])
  @@index([showtimeId, lockedUntil])
  @@index([userId, showtimeId])
  @@map("seat_locks")
}

// ==========================================
// 11. BOOKINGS
// ==========================================
model Booking {
  id                 Int           @id @default(autoincrement()) @map("booking_id")
  userId             Int           @map("user_id")
  showtimeId         Int           @map("showtime_id")
  status             BookingStatus @default(pending)
  totalAmount        Decimal       @default(0.00) @map("total_amount") @db.Decimal(10, 2)
  cancellationReason String?       @map("cancellation_reason") @db.Text
  bookingTime        DateTime      @default(now()) @map("booking_time")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id])
  showtime     Showtime      @relation(fields: [showtimeId], references: [id])
  bookingSeats BookingSeat[]
  payments     Payment[]
  bookingItems BookingItem[]

  @@index([userId, bookingTime])
  @@index([showtimeId, status])
  @@map("bookings")
}

enum BookingStatus {
  pending
  confirmed
  cancelled
}

// ==========================================
// 12. BOOKING SEATS
// ==========================================
model BookingSeat {
  id         Int     @id @default(autoincrement())
  bookingId  Int     @map("booking_id")
  showtimeId Int     @map("showtime_id")
  seatId     Int     @map("seat_id")
  price      Decimal @db.Decimal(10, 2)

  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  showtime Showtime @relation(fields: [showtimeId], references: [id])
  seat     Seat     @relation(fields: [seatId], references: [id])

  @@unique([showtimeId, seatId])
  @@index([bookingId])
  @@map("booking_seats")
}

// ==========================================
// 13. PAYMENTS
// ==========================================
model Payment {
  id            Int           @id @default(autoincrement()) @map("payment_id")
  bookingId     Int           @map("booking_id")
  amount        Decimal       @db.Decimal(10, 2)
  paymentMethod PaymentMethod @default(upi) @map("payment_method")
  transactionId String?       @unique @map("transaction_id") @db.VarChar(255)
  status        PaymentStatus @default(pending)
  paymentTime   DateTime      @default(now()) @map("payment_time")

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId, status])
  @@map("payments")
}

enum PaymentMethod {
  credit_card
  debit_card
  upi
  net_banking
  cash_at_counter
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

// ==========================================
// 14. MENU ITEMS
// ==========================================
model MenuItem {
  id          Int           @id @default(autoincrement()) @map("item_id")
  name        String        @db.VarChar(100)
  description String?       @db.Text
  price       Decimal       @db.Decimal(10, 2)
  category    String?       @db.VarChar(50)
  isAvailable Boolean       @default(true) @map("is_available")
  createdAt   DateTime      @default(now()) @map("created_at")

  bookingItems BookingItem[]

  @@map("menu_items")
}

// ==========================================
// 15. BOOKING ITEMS
// ==========================================
model BookingItem {
  id        Int     @id @default(autoincrement())
  bookingId Int     @map("booking_id")
  itemId    Int     @map("item_id")
  quantity  Int     @default(1)
  price     Decimal @db.Decimal(10, 2)

  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [itemId], references: [id])

  @@map("booking_items")
}

// ==========================================
// 16. REVIEWS
// ==========================================
model Review {
  id        Int      @id @default(autoincrement()) @map("review_id")
  userId    Int      @map("user_id")
  movieId   Int      @map("movie_id")
  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User  @relation(fields: [userId], references: [id])
  movie Movie @relation(fields: [movieId], references: [id])

  @@unique([userId, movieId])
  @@map("reviews")
}